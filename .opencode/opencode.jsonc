{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "openpets": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@open-pets/cli@2.1.1",
        "mcp",
        "--pet",
        "bebe-madoka-magica"
      ],
      "enabled": true
    },
    "pydoll": {
      "type": "local",
      "command": [
        "C:\\Users\\Yuri\\anaconda3\\python.exe",
        "-m",
        "pydoll_mcp_server.cli",
        "--transport",
        "stdio"
      ],
      "enabled": true,
      "env": {
        "PYDOLL_MCP_ALLOW_NO_AUTH": "true"
      }
    }
  },
  "instructions": [
    ".opencode/openpets.md"
  ],
  "plugin": [
    [
      "@open-pets/opencode@2.1.1",
      {
        "pet": "bebe-madoka-magica"
      }
    ]
  ]
}
